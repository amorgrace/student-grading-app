// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}
datasource db {
  provider = "postgresql"
}

model BlacklistedToken {
  id        String   @id @default(cuid())
  token     String   @unique
  createdAt DateTime @default(now())
}

enum Role {
  student
  teacher
}

model User {
  id        String   @id @default(cuid())
  fullName  String
  email     String   @unique
  password  String
  role      Role     @default(student)
  teacher   Teacher?
  student   Student?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

}

model Teacher {
  id          String       @id @default(cuid())
  userId      String       @unique
  user        User         @relation(fields: [userId], references: [id])
  assignments Assignment[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Student {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  classes   Classes?    @relation(fields: [classId], references: [id])
  classId   String?
  submissions Submission[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([classId])
}

model Classes {
  id          String       @id @default(cuid())
  name        String       @unique
  students    Student[]
  assignments Assignment[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Subject {
  id          String       @id @default(cuid())
  name        String       @unique
  assignments Assignment[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

enum AssignmentStatus {
  completed
  incomplete
}

enum SubmissionStatus {
  graded
  ungraded
}

model Assignment {
  id           String       @id @default(cuid())
  title        String
  question     String?
  fileUrl      String? 
  deadline     DateTime
  totalMarks   Int
  status       AssignmentStatus @default(incomplete)
  teacher      Teacher      @relation(fields: [teacherId], references: [id])
  teacherId    String
  classes      Classes      @relation(fields: [classId], references: [id])
  classId      String
  subject      Subject      @relation(fields: [subjectId], references: [id])
  subjectId    String
  submissions  Submission[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([teacherId])
  @@index([classId])
  @@index([subjectId])
  @@index([teacherId, createdAt])
  @@index([classId, createdAt])
}

model Submission {
  id           String     @id @default(cuid())
  assignment   Assignment @relation(fields: [assignmentId], references: [id])
  assignmentId String
  student      Student    @relation(fields: [studentId], references: [id])
  studentId    String
  answer       String?  
  fileUrl      String?
  score        Int?
  grade        String?
  status       SubmissionStatus @default(ungraded)
  feedback     String?
  submittedAt  DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([assignmentId])
  @@index([studentId])
  @@index([assignmentId, submittedAt])
  @@index([studentId, submittedAt])
  @@unique([assignmentId, studentId])
}

                },
                "classId": {
                  "type": "string",
                  "example": "classId here"
                },
                "subjectId": {
                  "type": "string",
                  "example": "subjectId here"
                }
              }
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Created"

    "/api/teacher/assignments": {
      "post": {
        "tags": [
          "Teacher"
        ],
        "summary": "Create a new assignment",
        "description": "Creates a new assignment for a specific class and subject. Teacher can provide a question as text or upload a file via Cloudinary URL. A deadline and total marks must be provided.",
        "parameters": [
          {
            "name": "authorization",
            "in": "header",
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "title": {
                  "type": "string",
                  "example": "Math Assignment"
                },
                "question": {
                  "type": "string",
                  "example": "Solve the following..."
                },
                "fileUrl": {
                  "type": "string",
                  "example": "https://cloudinary.com/file.pdf"
                },
                "deadline": {
                  "type": "string",
                  "example": "2026-04-01T00:00:00.000Z"
                },
                "totalMarks": {
                  "type": "number",
                  "example": 100
                },
                "classId": {
                  "type": "string",
                  "example": "classId here"
                },
                "subjectId": {
                  "type": "string",
                  "example": "subjectId here"
                }
              }
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      },
